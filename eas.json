{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "dev",
        "APP_NAME": "Itaim Prime Lounge",
        "APP_SLUG": "itaim-prime-lounge"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "homolog",
        "APP_NAME": "Itaim Prime Lounge",
        "APP_SLUG": "itaim-prime-lounge"
      }
    },
    "production": {
      "env": {
        "APP_ENV": "prod",
        "APP_NAME": "Itaim Prime Lounge",
        "APP_SLUG": "itaim-prime-lounge"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
